
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Production Flow Explorer</title>

<style>
body {
  background: #060b14;
  color: #c8e6f8;
  font-family: monospace;
  padding: 30px;
}

h1 {
  color: #00d4ff;
  text-align: center;
  margin-bottom: 20px;
}

select {
  width: 100%;
  padding: 12px;
  margin-bottom: 20px;
  background: #0c1524;
  color: #00d4ff;
  border: 1px solid #00d4ff;
  border-radius: 6px;
}

.card {
  display: inline-block;
  padding: 12px 16px;
  margin: 8px;
  border-radius: 8px;
  border: 1px solid #1a3a5c;
  cursor: pointer;
  transition: 0.2s;
}

.card:hover {
  border-color: #00d4ff;
  background: rgba(0,212,255,0.1);
}

.endpoint {
  border-color: #ff6b35;
  color: #ff9966;
}

.chain {
  margin-bottom: 15px;
}

.chain span {
  margin-right: 6px;
  cursor: pointer;
  color: #00d4ff;
}

.chain span:hover {
  text-decoration: underline;
}
</style>
</head>

<body>

<h1>Production Flow Explorer</h1>

<select id="node-select" onchange="selectNode(this.value)">
  <option value="">Select Node</option>
</select>

<div class="chain" id="chain"></div>

<div id="output"></div>

<script>

const flowData = {
  "F00": ["F01"],
  "F01": ["P01", "P02", "PINT"],
  "P01": ["AOUT", "APC", "WAFOUT", "ARDL"],
  "P02": ["ARDL", "AOUT", "APC"],
  "PINT": ["P01"],
  "AOUT": ["TSOUT"],
  "APC": ["AOUT", "APC", "APP"],
  "WAFOUT": ["AFGPN"],
  "ARDL": ["APP", "AOUT", "APC"],
  "TSOUT": ["TFGPN"],
  "APP": ["APP2"],
  "APP2": ["DOUT"],
  "DOUT": ["DFGPN"],
  "TFGPN": ["MINT", "MFGPN", "MCTO", "MODOUT"],
  "MINT": ["MFGPN", "MODOUT"],
  "MFGPN": ["MFGPN"],
  "MCTO": ["CFGPN"],
  "MODOUT": ["RFGPN"],
  "CFGPN": ["RFGPN"],
  "RFGPN": [],
  "DFGPN": [],
  "AFGPN": []
};

// ✅ populate dropdown
const dropdown = document.getElementById("node-select");
Object.keys(flowData).forEach(n => {
  let opt = document.createElement("option");
  opt.value = n;
  opt.textContent = n;
  dropdown.appendChild(opt);
});

let path = [];

// ✅ main selection logic
function selectNode(node) {
  if (!node) return;

  path.push(node);
  render();
}

// ✅ render UI
function render() {
  const output = document.getElementById("output");
  const chainDiv = document.getElementById("chain");

  // show path
  chainDiv.innerHTML = "";
  path.forEach((p, i) => {
    let span = document.createElement("span");
    span.textContent = p;
    span.onclick = () => {
      path = path.slice(0, i + 1);
      render();
    };
    chainDiv.appendChild(span);

    if (i < path.length - 1) {
      chainDiv.append(" → ");
    }
  });

  let current = path[path.length - 1];
  let outputs = flowData[current] || [];

  output.innerHTML = "";

  if (outputs.length === 0) {
    output.innerHTML = "<p>No further outputs (END NODE)</p>";
    return;
  }

  outputs.forEach(o => {
    let div = document.createElement("div");
    div.className = "card";

    if (flowData[o].length === 0) {
      div.classList.add("endpoint");
    }

    div.textContent = o;

    div.onclick = () => {
      selectNode(o);
    };

    output.appendChild(div);
  });
}

</script>

</body>
</html>
